{
  "name": "starlist",
  "version": "3.0.0",
  "description": "Generate a list from user starred GitHub repositories",
  "author": "Austin Ziegler",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "package": "ncc build --source-map --license licenses.txt --minify",
    "all": "pnpm run build && pnpm run check && pnpm run package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/halostatue/starlist.git"
  },
  "keywords": [
    "github",
    "action",
    "awesome",
    "list",
    "generator",
    "typescript",
    "javascript"
  ],
  "bugs": {
    "url": "https://github.com/halostatue/starlist/issues"
  },
  "homepage": "https://github.com/halostatue/starlist#readme",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "ejs": "^3.1.10",
    "gh-star-fetch": "^1.5.0",
    "got": "^14.4.3",
    "remark": "^15.0.1",
    "remark-toc": "^9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@octokit/rest": "^21.0.2",
    "@octokit/types": "^13.6.1",
    "@types/ejs": "^3.1.5",
    "@types/got": "^9.6.12",
    "@types/node": "^20.16.13",
    "@types/sinon": "^17.0.3",
    "@vercel/ncc": "^0.38.2",
    "markdown-toc": "^1.2.0",
    "sinon": "^19.0.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.1+sha512.e5a7e52a4183a02d5931057f7a0dbff9d5e9ce3161e33fa68ae392125b79282a8a8a470a51dfc8a0ed86221442eb2fb57019b0990ed24fab519bf0e1bc5ccfc4"
}
